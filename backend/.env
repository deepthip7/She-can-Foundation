# ─── She Can Foundation – Backend Environment Variables ───
# Copy this file to .env and fill in your values

PORT=5000

# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://localhost:27017/shecan
# Example Atlas: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/shecan

# JWT secret (change to a long random string in production)
JWT_SECRET=shecan_super_secret_jwt_key_2025

# JWT expiry
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
